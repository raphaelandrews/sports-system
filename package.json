{
  "name": "sports-system",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.90.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"turbo dev\" \"bun run dev:backend\"",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:backend": "cd apps/api && uv run uvicorn app.main:app --reload --port 3000",
    "db:up": "cd apps/api && uv run python -m alembic upgrade head",
    "db:new": "cd apps/api && uv run python -m alembic revision --autogenerate -m",
    "db:down": "cd apps/api && uv run python -m alembic downgrade -1",
    "deploy": "NODE_ENV=production turbo -F @sports-system/infra deploy",
    "destroy": "turbo -F @sports-system/infra destroy",
    "check": "oxlint && oxfmt --write",
    "ci:api-types": "cd apps/api && PYTHONPATH=$(pwd) uv run python scripts/generate_openapi.py && cd ../web && bun run check:api:local"
  },
  "dependencies": {
    "@sports-system/env": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "dotenv": "catalog:",
    "react-markdown": "^10.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@sports-system/config": "workspace:*",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.1"
}
